# Пароли БД должны совпадать с password в deploy/config/*-config.yaml

COMPOSE_FILE=docker-compose.prod.yml

GATEWAY_BIND=127.0.0.1:8080

JWT_SECRET=change-me-long-random-string

AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change-me-auth-db
AUTH_DB_NAME=auth_db

PROJECT_DB_USER=project_user
PROJECT_DB_PASSWORD=change-me-project-db
PROJECT_DB_NAME=project_db

ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=change-me-analytics-db
ANALYTICS_DB_NAME=analytics_db

NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=change-me-notification-db
NOTIFICATION_DB_NAME=notification_db

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

BACKUP_DIR=/var/backups/building-services
